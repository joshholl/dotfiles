#!/bin/bash
# {{ template "scripts-library" . }}
true || source ../../.chezmoitemplates/scripts-library
# Installs system-level packages that mise cannot provide (libraries, core utilities).
# CLI tools (bat, eza, fzf, etc.) are managed by mise via run_onchange_10-install-mise-tools.

{{ if eq .chezmoi.os "linux" }}
{{ $osid := .osid }}

log_task "Installing system packages ({{ $osid }})"

{{ if hasPrefix "linux-ubuntu" $osid | or (hasPrefix "linux-debian" $osid) }}
sudo apt-get update -qq
sudo apt-get install -y --no-install-recommends \
  curl \
  git \
  gnupg \
  ca-certificates \
  software-properties-common \
  zsh \
  build-essential

log_info "System packages installed"

{{ else if hasPrefix "linux-arch" $osid }}
sudo pacman -Syu --noconfirm
sudo pacman -S --noconfirm --needed \
  curl git gnupg \
  zsh \
  base-devel

log_info "System packages installed"
{{ end }}

{{ end }}
