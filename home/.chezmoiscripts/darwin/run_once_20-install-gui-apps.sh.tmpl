#!/bin/bash
# {{ template "scripts-library" . }}
true || source ../../.chezmoitemplates/scripts-library
{{ if .personal }}

set -euo pipefail

# Ensure mise shims are on PATH (chezmoi runs scripts in bare bash)
export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:$PATH"

# ── App server ────────────────────────────────────────────────────────────────
# Set app_server_url in home/.chezmoidata/install.yaml to enable installs.
# Each app is fetched from: $APP_SERVER/<slug>/latest.<ext>
APP_SERVER="{{ .app_server_url }}"

if [ -z "$APP_SERVER" ]; then
  log_warn "app_server_url is not set in install.yaml — skipping GUI app installs"
  log_warn "Set app_server_url in home/.chezmoidata/install.yaml and re-run chezmoi apply"
  exit 0
fi

# ── Installer cache ───────────────────────────────────────────────────────────
# iCloud syncs cached installers across all your Macs.
# Delete a file from the cache to force a fresh download.
INSTALLER_CACHE="$HOME/Library/Mobile Documents/com~apple~CloudDocs/App Installers"
mkdir -p "$INSTALLER_CACHE" 2>/dev/null || true  # no-op if iCloud isn't signed in

# Download a file, using the cache if available.
# Usage: cached_curl <dest_path> <url> <cache_name>
#   cache_name: unique filename for the cache entry (e.g. "brave.dmg")
cached_curl() {
  local dest="$1" url="$2" cache_name="$3"
  local cached="$INSTALLER_CACHE/$cache_name"

  if [ -f "$cached" ]; then
    log_info "Using cached installer: $cache_name"
    cp "$cached" "$dest"
    return 0
  fi

  if curl -sSL --location --fail-with-body -o "$dest" "$url"; then
    if [ -d "$INSTALLER_CACHE" ] && [ -w "$INSTALLER_CACHE" ]; then
      cp "$dest" "$cached"
    fi
    return 0
  fi
  return 1
}

# ── Helpers ───────────────────────────────────────────────────────────────────

# Install a .app from a DMG served at $APP_SERVER/<slug>/<arch>/latest.dmg
# Usage: install_dmg "Display Name" "<slug>" "<arch>" "App Name.app"
#   Use "universal" for apps that ship a single binary for all architectures.
install_dmg() {
  local name="$1" slug="$2" arch="$3" app="$4"
  if [ -d "/Applications/$app" ]; then
    log_info "$name already installed — skipping"
    return 0
  fi
  log_info "Downloading $name..."
  local tmp_dir tmp url cache_name
  tmp_dir=$(mktemp -d)
  tmp="$tmp_dir/download.dmg"
  url="$APP_SERVER/$slug/$arch/latest.dmg"
  cache_name="$slug-$arch.dmg"
  if ! cached_curl "$tmp" "$url" "$cache_name"; then
    log_warn "$name download failed — check $url"
    rm -rf "$tmp_dir"
    return 0
  fi
  local volume
  volume=$(hdiutil attach "$tmp" -nobrowse -noverify 2>/dev/null \
    | awk -F'\t' '$NF ~ /^\/Volumes\//{gsub(/[[:space:]]+$/, "", $NF); print $NF}' \
    | tail -1)
  if [ -z "$volume" ]; then
    log_warn "$name: failed to mount DMG"
    rm -rf "$tmp_dir"
    return 0
  fi
  cp -R "$volume/$app" /Applications/
  hdiutil detach "$volume" -quiet 2>/dev/null || true
  rm -rf "$tmp_dir"
  log_info "$name installed"
}

# Install a .app from a ZIP served at $APP_SERVER/<slug>/<arch>/latest.zip
# Usage: install_zip "Display Name" "<slug>" "<arch>" "App Name.app"
install_zip() {
  local name="$1" slug="$2" arch="$3" app="$4"
  if [ -d "/Applications/$app" ]; then
    log_info "$name already installed — skipping"
    return 0
  fi
  log_info "Downloading $name..."
  local tmp_dir tmp url cache_name
  tmp_dir=$(mktemp -d)
  tmp="$tmp_dir/download.zip"
  url="$APP_SERVER/$slug/$arch/latest.zip"
  cache_name="$slug-$arch.zip"
  if ! cached_curl "$tmp" "$url" "$cache_name"; then
    log_warn "$name download failed — check $url"
    rm -rf "$tmp_dir"
    return 0
  fi
  unzip -q "$tmp" -d "$tmp_dir/extracted"
  find "$tmp_dir/extracted" -maxdepth 2 -name "*.app" -exec cp -R {} /Applications/ \;
  rm -rf "$tmp_dir"
  log_info "$name installed"
}

# Install via a .pkg served at $APP_SERVER/<slug>/<arch>/latest.pkg
# Usage: install_pkg "Display Name" "<slug>" "<arch>" "App Name.app"
install_pkg() {
  local name="$1" slug="$2" arch="$3" app="$4"
  if [ -n "$app" ] && [ -d "/Applications/$app" ]; then
    log_info "$name already installed — skipping"
    return 0
  fi
  if [ -z "$app" ] && has_cmd "$name"; then
    log_info "$name already installed — skipping"
    return 0
  fi
  log_info "Downloading $name..."
  local tmp_dir tmp url cache_name
  tmp_dir=$(mktemp -d)
  tmp="$tmp_dir/download.pkg"
  url="$APP_SERVER/$slug/$arch/latest.pkg"
  cache_name="$slug-$arch.pkg"
  if ! cached_curl "$tmp" "$url" "$cache_name"; then
    log_warn "$name download failed — check $url"
    rm -rf "$tmp_dir"
    return 0
  fi
  sudo installer -pkg "$tmp" -target /
  rm -rf "$tmp_dir"
  log_info "$name installed"
}

log_task "Installing macOS GUI apps from $APP_SERVER"

# ── Arch ──────────────────────────────────────────────────────────────────────
if [ "$(uname -m)" = "arm64" ]; then
  ARCH="arm64"
else
  ARCH="x86_64"
fi

# ── Apps ──────────────────────────────────────────────────────────────────────

install_zip  "WezTerm"              "wezterm"           "$ARCH"      "WezTerm.app"
install_pkg  "mas"                  "mas"               "$ARCH"      ""
install_pkg  "YubiKey Manager"     "yubikey-manager"   "universal"  "YubiKey Manager.app"
install_dmg  "Brave"               "brave"             "$ARCH"      "Brave Browser.app"
install_dmg  "Telegram"            "telegram"          "universal"  "Telegram.app"
install_dmg  "Discord"             "discord"           "universal"  "Discord.app"
install_dmg  "Docker Desktop"      "docker"            "$ARCH"      "Docker.app"
install_zip  "Visual Studio Code"  "vscode"            "$ARCH"      "Visual Studio Code.app"
install_dmg  "VLC"                 "vlc"               "$ARCH"      "VLC.app"
install_dmg  "DBeaver"             "dbeaver"           "$ARCH"      "DBeaver.app"
install_dmg  "Obsidian"            "obsidian"          "universal"  "Obsidian.app"
install_zip  "Mountain Duck"       "mountain-duck"     "universal"  "Mountain Duck.app"
install_dmg  "OnyX"                "onyx"              "universal"  "OnyX.app"
install_dmg  "Scribus"             "scribus"           "universal"  "Scribus.app"

# ── Adobe Creative Cloud ──────────────────────────────────────────────────────
if [ ! -d "/Applications/Adobe Creative Cloud/Adobe Creative Cloud.app" ] && \
   [ ! -d "/Applications/Utilities/Adobe Creative Cloud/ACC/Creative Cloud.app" ]; then
  log_info "Downloading Adobe Creative Cloud..."
  tmp_dir=$(mktemp -d) && tmp="$tmp_dir/download.dmg"
  if cached_curl "$tmp" "$APP_SERVER/adobe-creative-cloud/universal/latest.dmg" "adobe-creative-cloud-universal.dmg"; then
    volume=$(hdiutil attach "$tmp" -nobrowse -noverify 2>/dev/null \
      | awk -F'\t' '$NF ~ /^\/Volumes\//{gsub(/[[:space:]]+$/, "", $NF); print $NF}' \
      | tail -1)
    if [ -n "$volume" ]; then
      pkg=$(find "$volume" -name "*.pkg" | head -1)
      if [ -n "$pkg" ]; then
        sudo installer -pkg "$pkg" -target /
        log_warn "Adobe Creative Cloud installed — open it and install Photoshop, Lightroom Classic"
      else
        log_warn "Adobe Creative Cloud: no .pkg found in DMG"
      fi
      hdiutil detach "$volume" -quiet 2>/dev/null || true
    else
      log_warn "Adobe Creative Cloud: failed to mount DMG"
    fi
  else
    log_warn "Adobe Creative Cloud download failed — check $APP_SERVER/adobe-creative-cloud/universal/latest.dmg"
  fi
  rm -rf "$tmp_dir"
else
  log_info "Adobe Creative Cloud already installed — skipping"
fi

# ── Mac App Store ─────────────────────────────────────────────────────────────
if ! has_cmd mas; then
  log_warn "mas not found — skipping App Store installs (run: mise install)"
else
  log_task "Installing App Store apps"
  # Verify IDs with: mas search "<name>"
  mas install 571213070   # DaVinci Resolve
  mas install 1451685025  # WireGuard
  mas install 1532579087  # CamelCamelCamel
fi

log_task "GUI app installation complete"
{{ else }}
echo "Not a personal machine — skipping GUI app install"
{{ end }}
