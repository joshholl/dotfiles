#!/bin/bash
# {{ template "scripts-library" . }}
true || source ../../.chezmoitemplates/scripts-library

# depends-on: catppuccin-mocha.terminal sha256: {{ include (joinPath .chezmoi.sourceDir "dot_config/terminal/catppuccin-mocha.terminal") | sha256sum }}

set -euo pipefail

PROFILE_NAME="catppuccin-mocha"
# Read from the chezmoi source dir — reliable even on a first-time apply
# before the target file has been deployed.
THEME_FILE="{{ .chezmoi.sourceDir }}/dot_config/terminal/catppuccin-mocha.terminal"

log_task "Configuring Terminal.app"

# ── Import profile and configure via AppleScript ─────────────────────────────
# Opening the .terminal file via AppleScript imports it into Terminal's live
# memory immediately — avoiding the stale-cache problem with `defaults import`.
# Font (NSFont archive) and default/startup profile are all set in one pass.
log_info "Importing $PROFILE_NAME and configuring Terminal..."
osascript << ASEOF
tell application "Terminal"
    open POSIX file "$THEME_FILE"
    delay 1
    set theSettings to settings set "$PROFILE_NAME"
    set font name of theSettings to "HackNFM-Regular"
    set font size of theSettings to 13
    set default settings to theSettings
    set startup settings to theSettings
end tell
ASEOF

log_task "Terminal.app configuration complete — restart Terminal to see changes"
