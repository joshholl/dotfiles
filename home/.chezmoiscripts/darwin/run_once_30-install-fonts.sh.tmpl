#!/bin/bash
# {{ template "scripts-library" . }}
true || source ../../.chezmoitemplates/scripts-library

set -euo pipefail

log_task "Installing fonts"

FONT_DIR="$HOME/Library/Fonts"
mkdir -p "$FONT_DIR"

# ── Hack Nerd Font ───────────────────────────────────────────────────────────
# Check for any existing Hack Nerd Font file
if ls "$FONT_DIR"/HackNerdFont-*.ttf >/dev/null 2>&1; then
  log_info "Hack Nerd Font already installed — skipping"
else
  log_info "Fetching latest Hack Nerd Font release..."
  URL=$(curl -fsSL "https://api.github.com/repos/ryanoasis/nerd-fonts/releases/latest" \
    | grep '"browser_download_url"' \
    | grep 'Hack\.tar\.xz"' \
    | head -1 \
    | sed 's/.*"browser_download_url": "\(.*\)"/\1/' \
    | tr -d '"')

  if [ -z "$URL" ]; then
    log_warn "Could not determine Hack Nerd Font URL — skipping"
  else
    tmp=$(mktemp /tmp/fonts-XXXXXX.tar.xz)
    log_info "Downloading $URL..."
    curl -fsSL --location -o "$tmp" "$URL"
    tmpdir=$(mktemp -d /tmp/fonts-XXXXXX)
    tar -xJf "$tmp" -C "$tmpdir"
    find "$tmpdir" -name '*.ttf' -exec cp {} "$FONT_DIR/" \;
    rm -rf "$tmp" "$tmpdir"
    log_info "Hack Nerd Font installed"
  fi
fi

log_task "Font installation complete"
