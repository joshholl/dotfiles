# ~/.ssh/config
# Private — mode 600 enforced by chezmoi's private_ prefix

# ── Global defaults ───────────────────────────────────────────────────────────
Host *
    ServerAliveInterval  60
    ServerAliveCountMax  3
    AddKeysToAgent       yes
    IdentitiesOnly       yes
    HashKnownHosts       yes
{{ if or .personal .work }}
    IdentityAgent        "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{ end }}

# ── GitHub ────────────────────────────────────────────────────────────────────
Host github.com
    User          git
    HostName      github.com
    IdentityFile  ~/.ssh/id_github.pub

# ── GitLab ────────────────────────────────────────────────────────────────────
Host gitlab.com
    User          git
    HostName      gitlab.com
{{ if .personal }}
    IdentityFile  ~/.ssh/id_personal
{{ end }}

# ── Local overrides ───────────────────────────────────────────────────────────
# Add machine-specific hosts in ~/.ssh/config.local (not tracked)
Include config.local
