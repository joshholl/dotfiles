{{/* ------------------------------------------------------------------ */}}
{{/*  Machine-type flags                                                  */}}
{{/* ------------------------------------------------------------------ */}}
{{- $personal := false -}}
{{- $work     := false -}}
{{- $headless := false -}}

{{/* Detect non-interactive/headless environments */}}
{{- if or (env "CI") (env "SSH_CLIENT") (env "SSH_TTY") -}}
{{-   $headless = true -}}
{{- end -}}

{{/* Compute a fine-grained OS id (e.g. "linux-ubuntu", "linux-arch") */}}
{{- $osid := .chezmoi.os -}}
{{- if and (eq .chezmoi.os "linux") .chezmoi.osRelease.id -}}
{{-   $osid = printf "linux-%s" .chezmoi.osRelease.id -}}
{{- end -}}

{{/* Interactive machine-type prompt (persisted after first run) */}}
{{- if stdinIsATTY -}}
{{-   $personal = promptBoolOnce . "personal" "Is this a personal machine" -}}
{{-   if not $personal -}}
{{-     $work = promptBoolOnce . "work" "Is this a work machine" -}}
{{-   end -}}
{{- end -}}

{{/* Git identity */}}
{{- $name  := promptStringOnce . "name"  "Full name" -}}
{{- $email := promptStringOnce . "email" "Email address" -}}

{{/* ------------------------------------------------------------------ */}}
{{/*  Hardware profile — selects AI model tier based on available RAM    */}}
{{/* ------------------------------------------------------------------ */}}
{{- $memGB := 0 -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $memBytes := output "sysctl" "-n" "hw.memsize" | trim | atoi -}}
{{-   $memGB = div $memBytes 1073741824 -}}
{{- end -}}

{{/* Primary model: heavy reasoning/chat/agentic work */}}
{{- $ollamaPrimary := "qwen2.5-coder:7b" -}}
{{- if ge $memGB 32 -}}
{{-   $ollamaPrimary = "qwen2.5-coder:32b" -}}
{{- else if ge $memGB 16 -}}
{{-   $ollamaPrimary = "qwen2.5-coder:14b" -}}
{{- end -}}

{{/* ------------------------------------------------------------------ */}}
{{/*  Config output                                                       */}}
{{/* ------------------------------------------------------------------ */}}
[data]
    personal = {{ $personal }}
    work     = {{ $work }}
    headless = {{ $headless }}
    osid     = {{ $osid | quote }}
    name     = {{ $name | quote }}
    email    = {{ $email | quote }}

    # AI / Ollama — derived from hardware RAM ({{ $memGB }}GB detected)
    memoryGB           = {{ $memGB }}
    ollamaPrimaryModel = {{ $ollamaPrimary | quote }}
    ollamaFillModel    = "qwen2.5-coder:1.5b"
    ollamaEmbedModel   = "nomic-embed-text"

[diff]
    exclude = ["scripts"]

[status]
    exclude = ["always"]

{{- if $work }}

# 1Password SSH agent — work machines only
[onepassword]
    command = "op"
{{- end }}
