# ~/.config/mise/config.toml
# Global tool declarations — managed by chezmoi.
# Run `mise install` to install all tools, `mise upgrade` to update.

[settings]
experimental = true              # required for aqua/ubi backends
fetch_remote_versions_cache = "1d"   # only hit GitHub once per day
fetch_remote_versions_timeout = "300"  # seconds before giving up silently
http_timeout = "300"                 # seconds for binary downloads

[tools]
# Shell
starship    = "latest"

#editor
neovim      = "latest"
tree-sitter = "latest"

# Node.js — required for TypeScript LSP, prettier, eslint_d, and other mason tools
node        = "lts"

# Python — required for mason tools (isort, black, etc.)
python      = "latest"

# Modern CLI replacements
bat         = "latest"
eza         = "latest"
fd          = "latest"
fzf         = "latest"
ripgrep     = "latest"
jq          = "latest"
yq          = "latest"
delta       = "latest"
direnv      = "latest"
rclone      = "latest"
fx          = "latest"

# Docker without docker desktop
lazydocker  = "latest"
colima      = "latest"
docker-cli  = "latest"
docker-compose = "latest"

# GitHub CLI
"github-cli" = "latest"

# Kubernetes
kubectl     = "latest"
k9s         = "latest"
helm        = "latest"
stern       = "latest"

# JVM / Clojure
java        = "temurin-21"
clojure     = "latest"

# Python tooling
uv          = "latest"

# Git / workflow
lazygit     = "latest"
just        = "latest"

# Shell enhancements
zoxide      = "latest"
atuin       = "latest"

# chezmoi — managed here so mise shim resolves after first bootstrap
chezmoi     = "latest"

{{ if .personal }}
# Self-hosted model management — personal machines only (blocked on work)
ollama     = "latest"
{{ end }}

{{ if .personal }}
# Secrets — personal machines only
age         = "latest"
sops        = "latest"
mas         = "latest"
semgrep     = "latest"
{{ end }}
