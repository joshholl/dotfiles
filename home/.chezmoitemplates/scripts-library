#!/bin/bash
# Reusable bash library — included in scripts via: {{ "{{ template scripts-library . }}" }}
# Sourced line for ShellCheck: true || source ../.chezmoitemplates/scripts-library

set -euo pipefail

# ── Colour codes ──────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Colour

# ── Logging helpers ───────────────────────────────────────────────────────────
log_task()    { echo -e "${BLUE}==> ${*}${NC}"; }
log_info()    { echo -e "${GREEN}    ${*}${NC}"; }
log_warn()    { echo -e "${YELLOW}    WARN: ${*}${NC}"; }
log_error()   { echo -e "${RED}    ERROR: ${*}${NC}" >&2; }

# Run a command and print it first
c() {
  echo -e "${YELLOW}    \$${NC} ${*}"
  "$@"
}

# ── Privilege helpers ─────────────────────────────────────────────────────────
if [ "$(id -u)" -eq 0 ]; then
  sudo() { "$@"; }
fi

# ── Package manager helpers ───────────────────────────────────────────────────
has_cmd() { command -v "$1" >/dev/null 2>&1; }
