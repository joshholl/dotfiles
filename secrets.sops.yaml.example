# Example structure for home/.chezmoidata/secrets.sops.yaml
#
# To create the encrypted file:
#   1. Copy to secrets.yaml and fill in your values
#   2. sops --encrypt secrets.yaml > secrets.sops.yaml
#   3. rm secrets.yaml
#   4. git add secrets.sops.yaml
#
# To use a value in a chezmoi template:
#   {{- $s := output "sops" "--decrypt" (joinPath .chezmoi.sourceDir "home/.chezmoidata/secrets.sops.yaml") | fromYaml -}}
#   {{ $s.github_token }}

github_token: ""

# DaVinci Resolve — obtain a signed download URL from:
# https://www.blackmagicdesign.com/products/davinciresolve
# The URL is long-lived. Store it here so the install script can use it.
davinci_resolve_url: ""
